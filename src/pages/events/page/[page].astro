---
import MoodEmpty from "@tabler/icons/outline/mood-empty.svg";
import type { GetStaticPaths, Page } from "astro";
import Badge from "@/components/astro/Badge.astro";
import ClickableCard from "@/components/astro/Card/ClickableCard.astro";
import EventCard from "@/components/astro/Card/EventCard.astro";
import Pagination from "@/components/astro/Pagination.astro";
import { PAGE_SIZE } from "@/consts";
import PageLayout from "@/layouts/PageLayout.astro";
import { type Event, getEvents } from "@/sanity/lib/queries/events";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const allPublishedEvents = (await getEvents()) || [];

	return paginate(allPublishedEvents, {
		pageSize: PAGE_SIZE,
	});
};

interface Props {
	page: Page;
}

const { page } = Astro.props;

const pageTitle = "Our latest events";
const pageDescription =
	"Explore upcoming and past events organized by our community.";
---

<PageLayout title={pageTitle} description={pageDescription} dataPagefindIgnore="all">
  <header class="flex flex-col items-center justify-center py-16 md:py-24">
    <div class="anim-header-badge opacity-0 scale-50">
      <Badge
        variant={"secondary"}
        size={"sm"}
        class="font-mono uppercase tracking-widest text-xs mb-3 border border-border/50"
      >
        Events Archive
      </Badge>
    </div>
    <h1
      class="anim-header-title invisible font-sans text-5xl md:text-7xl font-medium tracking-tighter pt-4 text-center max-w-4xl leading-tight"
    >
      Explore our latest events
    </h1>
  </header>
  <section class="mb-24" data-manual-card-anim>
    <h2
      class="anim-all-title font-sans text-xl md:text-2xl font-medium mb-8 uppercase tracking-wider border-b border-border/50 pb-2 opacity-0 translate-y-4"
    >
      All Events
    </h2>
  {
  page.data.length > 0 ? (
      <div class="flex flex-col gap-6 mb-12">
        {page.data.map((event: Event) => {
          return (
            <ClickableCard
              href={`/events/${event.slug}/`}
              class="anim-event-card group bg-secondary text-secondary-foreground rounded-2xl transition-colors overflow-hidden opacity-0 translate-y-4"
            >
              <EventCard data={event} />
            </ClickableCard>
          );
        })}
      </div>
      <div class="anim-pagination flex justify-center mt-16 opacity-0">
        <Pagination
          url={page.url}
          class="font-mono text-sm uppercase tracking-widest"
        />
      </div>
  ) : (
    <div class="anim-empty-state flex flex-col items-center justify-center py-16 text-center border border-dashed border-border/60 rounded-xl bg-secondary/5 opacity-0 scale-95">
        <div class="p-4 bg-secondary rounded-full mb-4">
          <MoodEmpty class="size-8 text-muted-foreground" />
        </div>
        <h3 class="font-sans text-xl font-medium mb-2">No upcoming events</h3>
        <p class="text-muted-foreground max-w-xs mx-auto">
          There are no events scheduled at the moment. Check back later for
          updates.
        </p>
      </div>
    )
  }
  </section>
</PageLayout>

<script>
  import { gsap, SplitText } from "@/utils/gsap-init";
  import { initCardSplitTextAnimation } from "@/utils/animations/cards-split-text-animation";

  {
    const mainTl = gsap.timeline({
      defaults: { ease: "power3.out" },
    });

    const titleSplit = SplitText.create(".anim-header-title", {
      type: "lines, words",
      linesClass: "overflow-hidden",
    });

    mainTl
      .to(".anim-header-badge", {
        scale: 1,
        opacity: 1,
        duration: 0.6,
        ease: "back.out(1.5)",
      })
      .set(".anim-header-title", { autoAlpha: 1 }, "-=0.3")
      .from(
        titleSplit.words,
        {
          yPercent: 100,
          opacity: 0,
          duration: 0.8,
          stagger: 0.04,
          ease: "power4.out",
        },
        "<"
      );
      mainTl.to(".anim-all-title", {
      y: 0,
      opacity: 1,
      duration: 0.5,
    }, "-=0.6");

    if (document.querySelector(".anim-event-card")) {
      mainTl
        .to(".anim-event-card", {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.08,
          ease: "power2.out",
        }, "-=0.6")
        .add(() => {
          initCardSplitTextAnimation({ cardSelector: ".anim-event-card" });
        }, "<");
    }

    if (document.querySelector(".anim-pagination")) {
      mainTl.to(".anim-pagination", {
        opacity: 1,
        duration: 0.5,
      }, "-=0.2");
    }

    if (document.querySelector(".anim-empty-state")) {
      mainTl.to(".anim-empty-state", {
        scale: 1,
        opacity: 1,
        duration: 0.6,
        ease: "back.out(1.2)",
      }, "-=0.4");
    }
  }
</script>