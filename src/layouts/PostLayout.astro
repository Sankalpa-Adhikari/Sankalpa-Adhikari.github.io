---
import { Image } from "astro:assets";
import ArrowLeft from "@tabler/icons/outline/arrow-left.svg";
import Categories from "@/components/Categories.astro";
import type { PostDetails } from "@/sanity/lib/queries/posts";
import FormattedDate from "../components/FormattedDate.astro";
import PageLayout from "./PageLayout.astro";

type Props = PostDetails;

const {
  title,
  subtitle,
  categories,
  description,
  publishedAt,
  heroImage,
  heroImageAlt,
  type,
  showToc,
} = Astro.props;

const backLinkConfig: Record<string, { href: string; label: string }> = {
  blog: { href: "/blog/page/1", label: "Back to All Blogs" },
  notice: { href: "/notices/page/1", label: "Back to All Notices" },
};

const { href: backHref, label: backLabel } =
  backLinkConfig[type] || backLinkConfig.blog;
---

<PageLayout title={title} description={description ?? title}>
  <article class="py-8 space-y-10" data-pagefind-body>
    <header class="space-y-8 border-b border-border pb-10">
      <a
        data-pagefind-ignore
        href={backHref}
        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-muted-foreground hover:text-primary transition-colors px-4"
      >
        <ArrowLeft class="size-4" />
        {backLabel}
      </a>
      <div class="space-y-4 text-center">
        <h1
          class="font-sans text-3xl md:text-5xl font-medium tracking-tighter first-letter:capitalize"
          data-pagefind-meta="title"
        >
          {title}
        </h1>
        {
          subtitle && (
            <p
              data-pagefind-meta="sub_title"
              class="font-sans text-lg text-muted-foreground leading-relaxed first-letter:capitalize max-w-3xl mx-auto"
            >
              {subtitle}
            </p>
          )
        }
      </div>

      <div class="flex flex-row justify-around items-center text-xs">
        {
          categories?.length > 0 ? (
            <Categories categories={categories} />
          ) : (
            <div />
          )
        }

        {
          publishedAt && (
            <span
              class="font-mono text-xs text-muted-foreground uppercase tracking-wider border-l border-border/50 pl-6"
              data-pagefind-meta={`date:${publishedAt}`}
              data-pagefind-ignore
            >
              <FormattedDate date={new Date(publishedAt)} />
            </span>
          )
        }
      </div>
    </header>

    {
      heroImage && (
        <div class="flex items-center justify-center overflow-hidden">
          <Image
            data-pagefind-meta="image[src], image_alt[alt]"
            inferSize
            class="object-cover rounded-xl max-h-1/2"
            src={heroImage}
            alt={heroImageAlt ?? ""}
          />
        </div>
      )
    }

    <div class={`mx-auto max-w-7xl ${showToc ? "xl:flex xl:gap-12" : ""}`}>
      <div class="prose w-full min-w-0 max-w-none dark:prose-invert">
        <slot />
      </div>

      {
        showToc && (
          <div class="hidden xl:block xl:w-64 xl:shrink-0">
            <div class="sticky top-24 max-h-[calc(100vh-6rem)] overflow-y-auto">
              <slot name="toc" />
            </div>
          </div>
        )
      }
    </div>

    {/* TODO:Content for related posts grid */}
    <!-- {
      relatedPosts && relatedPosts.length > 0 && (
        <div class="border-t border-border/50 pt-12 space-y-8">
          <div class="flex flex-col text-center gap-2">
            <h3 class="font-sans text-2xl font-medium tracking-tight">
              If You Liked This...
            </h3>
            <p class="font-sans text-muted-foreground">
              Explore similar topics
            </p>
          </div>

          <div class="grid gap-8">TO:DO</div> 
        </div>
      )
    } -->
  </article>
</PageLayout>
