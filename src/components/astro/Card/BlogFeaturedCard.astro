---
import { getEntries } from "astro:content";
import ArrowNarrowRight from "@tabler/icons/outline/arrow-narrow-right.svg";
import Image from "astro/components/Image.astro";
import Categories from "@/components/Categories.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { cn } from "@/lib/utils";
import type { Post } from "@/sanity/lib/queries/posts";
import AvatarGroup from "../AvatarGroup.astro";
import Separator from "../Separator";

type Props = {
  data: Post;
  class?: string;
};
const { data, class: className } = Astro.props;
const {
  title,
  subtitle,
  publishedAt,
  categories,
  authors,
  heroImage,
  heroImageAlt,
} = data;
---

<article
  class={cn(
    "split-card gap-4 gap-x-6 cursor-pointer group grid grid-cols-1 md:grid-cols-2 p-0 md:p-0 bg-secondary text-secondary-foreground rounded-2xl",
    className,
  )}
>
  <div
    class="col-span-1 flex flex-col min-h-64 gap-2 p-4 md:p-6 order-2 md:order-1"
  >
    <div class="flex flex-row flex-wrap gap-2 justify-between items-center">
      {
        categories?.length > 0 ? (
          <Categories badgeVariant={"outline"} categories={categories} />
        ) : (
          <div />
        )
      }

      {
        publishedAt && (
          <p class="font-mono text-xs uppercase tracking-wider text-muted-foreground">
            <FormattedDate date={new Date(publishedAt)} />
          </p>
        )
      }
    </div>
    <div class="flex flex-col gap-2 grow">
      <a
        class="split-target font-sans text-2xl md:text-3xl font-medium first-letter:capitalize leading-snug pb-1"
        href={`/blog/${data.slug}`}
      >
        {title}
      </a>
      {
        subtitle && (
          <span class="font-sans text-sm text-muted-foreground first-letter:capitalize">
            {subtitle}
          </span>
        )
      }
    </div>
    <Separator class={"my-4"} />
    <div class="flex flex-row justify-between items-center">
      <a
        class="font-mono text-xs uppercase tracking-widest flex flex-row gap-2 items-center hover:text-primary transition-colors"
        href={`/blog/${data.slug}`}
      >
        Read more <ArrowNarrowRight class="w-4 h-4" />
      </a>
      {authors?.length > 0 && <AvatarGroup data={authors} />}
    </div>
  </div>
  {
    heroImage && (
      <div class="col-span-1 rounded-t-xl md:rounded-l-none md:rounded-r-xl max-h-64 lg:min-h-80 overflow-hidden order-1 md:order-2">
        <Image
          inferSize
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-in-out"
          src={heroImage}
          alt={heroImageAlt ?? ""}
        />
      </div>
    )
  }
</article>

<script>
  import { initCardSplitTextAnimation } from "@/utils/animations/cards-split-text-animation";

  if (typeof window !== "undefined") {
    window.addEventListener("load", () => {
      initCardSplitTextAnimation();
    });
  }
</script>
