---
import ArrowNarrowRight from "@tabler/icons/outline/arrow-narrow-right.svg";
import Categories from "@/components/Categories.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import AvatarGroup from "../AvatarGroup.astro";

const { data, href } = Astro.props;
const { title, subtitle, publishedAt, categories, authors, slug } = data;
---

<article
  class="split-card space-y-2 cursor-pointer flex flex-col relative z-10 p-4"
>
  <div class="flex flex-row justify-between items-center">
    {categories?.length > 0 ? <Categories categories={categories} /> : <div />}

    {
      publishedAt && (
        <p class="font-mono text-xs text-muted-foreground uppercase tracking-wider">
          <FormattedDate date={new Date(publishedAt)} />
        </p>
      )
    }
  </div>

  <div class="flex flex-col gap-2 grow">
    <a
      class="split-target font-sans text-xl md:text-2xl font-medium first-letter:capitalize leading-snug"
      href={href ? href : `/blog/${slug}`}
    >
      {title}
    </a>
    {
      subtitle && (
        <span class="font-sans text-sm text-muted-foreground first-letter:capitalize">
          {subtitle}
        </span>
      )
    }
    <div class="flex flex-row items-center justify-between pt-4 pb-0 mt-auto">
      <a
        class="font-mono text-xs uppercase tracking-widest flex flex-row gap-2 items-center hover:text-primary transition-colors"
        href={href ? href : `/blog/${slug}`}
      >
        Read more <ArrowNarrowRight class="w-4 h-4" />
      </a>
      {authors?.length > 0 && <AvatarGroup data={authors} />}
    </div>
  </div>
</article>

<script>
  import { initCardSplitTextAnimation } from "@/utils/animations/cards-split-text-animation";

  if (typeof window !== "undefined") {
    window.addEventListener("load", () => {
      if (!document.querySelector("[data-manual-card-anim]")) {
        initCardSplitTextAnimation();
      }
    });
  }
</script>
