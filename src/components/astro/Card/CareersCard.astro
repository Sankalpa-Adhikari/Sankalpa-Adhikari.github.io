---
import ArrowNarrowRight from "@tabler/icons/outline/arrow-narrow-right.svg";
import MapPin from "@tabler/icons/outline/map-pin.svg";
import Point from "@tabler/icons/outline/point.svg";
import FormattedDate from "@/components/FormattedDate.astro";
import type { Vacancy } from "@/sanity/lib/queries/careers";
import Badge from "../Badge.astro";

type Props = {
  data: Vacancy;
  class?: string;
};

const { data, class: className } = Astro.props;

const today = new Date();
today.setHours(0, 0, 0, 0);

const closingDate = data.closingDate ? new Date(data.closingDate) : null;
closingDate?.setHours(0, 0, 0, 0);

const hasExpired = closingDate ? closingDate < today : false;

const isClosed = data.status === "closed" || hasExpired;
---

<article
  class="split-card space-y-2 cursor-pointer flex flex-col relative z-10 p-4"
>
  <div class="flex flex-row justify-between items-center">
    <div class="flex flex-wrap justify-items-start gap-2">
      <Badge
        size={"xs"}
        variant={"secondary"}
        class={"tracking-wide first-letter:capitalize"}
      >
        {data.type}
      </Badge>
      <Badge variant="outline">
        {data.company.name}
      </Badge>
    </div>
    {
      closingDate && !isClosed && (
        <span class="flex items-center gap-1 text-muted-foreground font-medium italic">
          <Point class="fill-destructive text-destructive w-3 h-3" />
          Closes: <FormattedDate date={closingDate} />
        </span>
      )
    }
    {isClosed && <Badge variant={"destructive"}>Position Closed</Badge>}
  </div>

  <h3
    class="split-target font-sans text-2xl md:text-3xl font-medium leading-snug"
  >
    {data.title}
  </h3>

  <div class="flex flex-row items-center justify-between">
    <div class="flex items-center gap-1.5 text-sm text-muted-foreground">
      <MapPin class="size-4" />
      <span>{data.location}</span>
    </div>
    <a
      class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest hover:text-primary transition-colors leading-none"
      href={`/careers/${data.slug}/`}
    >
      <span class="translate-y-[1px]">Learn more</span>
      <ArrowNarrowRight class="w-4 h-4 shrink-0" />
    </a>
  </div>
</article>

<script>
  import { initCardSplitTextAnimation } from "@/utils/animations/cards-split-text-animation";

  if (typeof window !== "undefined") {
    window.addEventListener("load", () => {
      initCardSplitTextAnimation();
    });
  }
</script>
