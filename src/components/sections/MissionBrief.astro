---
import { Image } from "astro:assets";
import ArrowRight from "@tabler/icons/outline/arrow-right.svg";
import PlayerPause from "@tabler/icons/outline/player-pause.svg";
import PlayerPlay from "@tabler/icons/outline/player-play.svg";
import Plus from "@tabler/icons/outline/plus.svg";
import MissionPlaceholder3 from "src/assets/pages/mission-placeholder-3.avif";
import Badge from "@/components/astro/Badge.astro";
import type { Home } from "@/sanity/lib/queries/home";

const { objective, bylaws } = Astro.props as {
  objective: Home["objective"];
  bylaws: Home["bylaws"];
};
---

<section
  id="mission-brief"
  class="mission-section relative space-y-12 pt-24 md:pt-32 bg-background text-foreground overflow-hidden"
>
  <div
    class="mission-text border-b border-border/50 pb-12 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8"
  >
    <div class="max-w-3xl">
      <div class="flex items-center gap-4 mb-4">
        <Badge class="font-mono text-xs uppercase tracking-widest" size="sm"
          >( 02 )</Badge
        >
        <span
          class="font-mono text-xs text-muted-foreground uppercase tracking-widest"
          >Mission Brief</span
        >
      </div>
      <h1
        class="text-5xl md:text-8xl font-sans font-medium tracking-tighter leading-[0.9] opacity-0 translate-y-8"
      >
        Objectives of the <br />
        <span class="text-muted-foreground italic font-serif">Society.</span>
      </h1>
    </div>
    <div class="max-w-xl lg:max-w-3xl">
      <p
        class="text-base md:text-lg text-muted-foreground font-sans leading-relaxed opacity-0 translate-y-8"
      >
        <span class="font-mono text-xs text-primary block mb-2"
          >[ SUMMARIZED OBJECTIVE ]</span
        >
        {objective.summaryText}
      </p>
    </div>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-[1fr_1fr] lg:grid-cols-[2fr_3fr] gap-4"
  >
    <div
      class="mission-card group relative rounded-2xl overflow-hidden bg-secondary min-h-[400px] lg:min-h-[600px] border border-border/50 opacity-0 translate-y-12 scale-95"
    >
      <Image
        alt={objective.imagePrimary.alt || ""}
        src={objective.imagePrimary.url}
        inferSize
        class="absolute w-full h-full top-0 left-0 object-cover transition-all duration-700 grayscale group-hover:grayscale-0 group-hover:scale-105"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60"
      >
      </div>

      <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 text-white z-10">
        <div
          class="flex justify-between items-end border-t border-white/20 pt-6"
        >
          <div>
            <h3
              class="font-mono text-xs uppercase tracking-widest mb-2 text-white/70"
            >
              Objective A
            </h3>
            <h1 class="font-sans text-3xl md:text-4xl font-medium leading-none">
              Uplifting professionalism
            </h1>
          </div>
          <ArrowRight
            class="w-6 h-6 text-white/50 group-hover:text-white transition-colors"
          />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 h-full">
      <div
        class="mission-card group rounded-2xl p-6 md:p-8 bg-secondary flex flex-col justify-between min-h-[200px] border border-border/50 hover:border-foreground/20 transition-colors opacity-0 translate-y-12 scale-95"
      >
        <div class="flex justify-between items-start">
          <Plus class="w-5 h-5 text-muted-foreground" />
          <span class="font-mono text-xs text-muted-foreground"
            >( {objective.metric1.name} )</span
          >
        </div>
        <div>
          <h3
            class="font-sans text-5xl md:text-6xl font-medium tracking-tight mb-2"
          >
            {objective.metric1.value}
          </h3>
          <p
            class="font-mono text-xs uppercase tracking-wider text-muted-foreground"
          >
            {objective.metric1.subtitle}
          </p>
        </div>
      </div>

      <div
        class="mission-card group relative rounded-2xl overflow-hidden bg-secondary min-h-[200px] border border-border/50 opacity-0 translate-y-12 scale-95"
      >
        <Image
          alt={objective.imageSecondary.alt || ""}
          src={objective.imageSecondary.url}
          inferSize
          class="absolute w-full h-full top-0 left-0 object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div
          class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors"
        >
        </div>
      </div>

      <div
        class="mission-card group rounded-2xl p-6 md:p-8 bg-secondary flex flex-col justify-between min-h-[200px] border border-border/50 hover:border-foreground/20 transition-colors opacity-0 translate-y-12 scale-95"
      >
        <div class="flex justify-between items-start">
          <Plus class="w-5 h-5 text-muted-foreground" />
          <span class="font-mono text-xs text-muted-foreground"
            >( {objective.metric2.name} )</span
          >
        </div>
        <div>
          <h3
            class="font-sans text-5xl md:text-6xl font-medium tracking-tight mb-2"
          >
            {objective.metric2.value}
          </h3>
          <p
            class="font-mono text-xs uppercase tracking-wider text-muted-foreground"
          >
            {objective.metric2.subtitle}
          </p>
        </div>
      </div>

      <div
        class="mission-card relative rounded-2xl overflow-hidden bg-black min-h-[250px] col-span-1 md:col-span-2 lg:col-span-1 xl:col-span-1 border border-border/50 opacity-0 translate-y-12 scale-95"
      >
        <video
          autoplay
          class="js-mission-video absolute w-full h-full top-0 left-0 object-cover opacity-80"
          loop
          muted
          playsinline
        >
          <source src={objective.videoPrimary} type="video/mp4" />
        </video>
        <div class="absolute bottom-4 right-4 z-20">
          <button
            class="js-video-btn bg-white/10 backdrop-blur-md border border-white/20 p-2 rounded-full hover:bg-white hover:text-black transition-all"
            aria-label="Toggle Video Playback"
          >
            <span class="js-pause-icon block">
              <PlayerPause class="w-4 h-4" />
            </span>
            <span class="js-play-icon hidden">
              <PlayerPlay class="w-4 h-4" />
            </span>
          </button>
        </div>
      </div>
    </div>

    <div
      class="mission-card group relative rounded-2xl overflow-hidden bg-secondary min-h-[350px] md:col-span-2 lg:col-span-2 flex items-center border border-border/50 opacity-0 translate-y-12 scale-95"
    >
      <Image
        alt="Background"
        src={MissionPlaceholder3}
        width="1200"
        class="absolute w-full h-full top-0 left-0 object-cover object-[0%_30%] opacity-40 group-hover:opacity-20 transition-opacity duration-700"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-black via-black/50 to-transparent z-0"
      >
      </div>

      <div class="relative z-10 w-full md:w-2/3 p-8 md:p-12 text-white">
        <div class="mb-6">
          <Badge class="font-mono border-white/30 capitalize">( Bylaws )</Badge>
        </div>
        <h3
          class="font-sans text-3xl md:text-5xl font-light mb-6 leading-tight"
        >
          By Laws of <span class="italic font-serif text-gray-400">NSAE</span>
        </h3>
        <p
          class="font-sans text-lg text-gray-300 mb-8 leading-relaxed max-w-lg"
        >
          {bylaws.description}
        </p>

        <a
          href={bylaws.file}
          target="_blank"
          class="group/btn flex items-center gap-4 font-mono text-xs uppercase tracking-widest hover:text-primary transition-colors"
        >
          Read the Full bylaws <ArrowRight
            class="w-4 h-4 transition-transform group-hover/btn:translate-x-2"
          />
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "@/utils/gsap-init";

  if (typeof window !== "undefined") {
    gsap
      .timeline({
        scrollTrigger: {
          trigger: ".mission-text",
          start: "top 80%",
          end: "top 50%",
          toggleActions: "play none none reverse",
        },
      })
      .to(".mission-text h1, .mission-text p", {
        y: 0,
        opacity: 1,
        duration: 1,
        stagger: 0.1,
        ease: "power3.out",
      });

    gsap
      .timeline({
        scrollTrigger: {
          trigger: ".mission-section .grid",
          start: "top 85%",
          end: "top 60%",
          toggleActions: "play none none reverse",
        },
      })
      .to(".mission-card", {
        y: 0,
        opacity: 1,
        scale: 1,
        stagger: 0.15,
        duration: 0.8,
        ease: "power2.out",
      });
    const videoBtn = document.querySelector(".js-video-btn");
    const video = document.querySelector(
      ".js-mission-video",
    ) as HTMLVideoElement; // Type casting for TS
    const pauseIcon = document.querySelector(".js-pause-icon");
    const playIcon = document.querySelector(".js-play-icon");

    if (videoBtn && video && pauseIcon && playIcon) {
      videoBtn.addEventListener("click", () => {
        if (video.paused) {
          video.play();
          playIcon.classList.add("hidden");
          pauseIcon.classList.remove("hidden");
        } else {
          video.pause();
          playIcon.classList.remove("hidden");
          pauseIcon.classList.add("hidden");
        }
      });
    }
  }
</script>
